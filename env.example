# Environment variables for SSM (Kaggle-friendly, no hardcoded paths)
# Copy to .env or export before running scripts.
#
# Required for Kaggle:
#   REPO_ROOT     - Project root (default: auto-detected)
#   EPICHAT_DIR   - EpiChat path (default: REPO_ROOT/epichat, in-repo)
#   WORK_DIR      - Output dir (default: /kaggle/working on Kaggle)
#   MODEL_DIR     - Model storage (default: ~/.ssm/models or WORK_DIR/models on Kaggle)
#   CONFIG_DIR    - Config storage (default: ~/.ssm or WORK_DIR/.ssm on Kaggle)
#   TMP_DIR       - Temp files (default: /tmp)
#   DATA_DIR      - Data directory (default: REPO_ROOT/data)
#   CHECKPOINT_DIR - Checkpoints (default: REPO_ROOT/checkpoints)
#
# Example (Kaggle notebook):
#   import os
#   os.environ['REPO_ROOT'] = '/kaggle/working/RS-Code-SSM'
#   os.environ['EPICHAT_DIR'] = '/kaggle/working/RS-Code-SSM/epichat'
#
# Example (shell):
#   source scripts/env.sh   # sets defaults from repo location
